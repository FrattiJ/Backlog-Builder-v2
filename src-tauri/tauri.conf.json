{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Hobbylog",
  "version": "0.3.2",
  "identifier": "com.hobbylog.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run next-dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Hobbylog",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preloadConnections": ["sqlite:hobbylog.db"]
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVDNzM1QzI4NjdBMUNDRjEKUldUeHpLRm5LRnh6N0c2R1k1SEVXNktrUlh4aU1Xc1hqdzk0dlhjYnp0TzdKRHgxRnU1ak81bDYK",
      "endpoints": [
        "https://github.com/FrattiJ/Backlog-Builder-v2/releases/latest/download/latest.json"
      ]
    }
  }
}
